# ==========================================================
#  B.L.A.S.T. SOVEREIGN STARTER PACK — Environment Template
# ----------------------------------------------------------
#  1. Copy this file to ".env"
#  2. Fill in the values you actually need
#  3. Any line you leave as YOUR_*_HERE will be ignored at runtime
# ==========================================================

# --- 1. CORE DATABASE (optional — agent_loop runs without it) ---
DATABASE_URL=postgresql://user:pass@host:5432/postgres
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_API_KEY=YOUR_SUPABASE_ANON_KEY_HERE
SUPABASE_SERVICE_KEY=YOUR_SUPABASE_SERVICE_KEY_HERE

# --- 2. AI / LLM PROVIDERS ---
OPENAI_API_KEY=YOUR_OPENAI_KEY_HERE
ANTHROPIC_API_KEY=YOUR_CLAUDE_KEY_HERE
GOOGLE_API_KEY=YOUR_GOOGLE_KEY_HERE
GROQ_API_KEY=YOUR_GROQ_KEY_HERE
OPENROUTER_API_KEY=YOUR_OPENROUTER_KEY_HERE
OLLAMA_MODEL=gemma31b

# --- 3. VECTOR / SEMANTIC MEMORY (optional) ---
PINECONE_API_KEY=YOUR_PINECONE_KEY_HERE
PINECONE_ENVIRONMENT=us-east-1
QDRANT_URL=https://your-cluster.cloud.qdrant.io:6333
QDRANT_API_KEY=YOUR_QDRANT_KEY_HERE

# --- 4. COMMUNICATIONS (Discord / Telegram / Slack) ---
DISCORD_BOT_TOKEN=YOUR_DISCORD_BOT_TOKEN_HERE
DISCORD_CHANNEL_ID=YOUR_CHANNEL_ID_HERE
DISCORD_WEBHOOK_URL=YOUR_WEBHOOK_URL_HERE

TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_CHAT_ID_HERE

SLACK_BOT_TOKEN=YOUR_SLACK_BOT_TOKEN_HERE
SLACK_SIGNING_SECRET=YOUR_SLACK_SIGNING_SECRET_HERE

# --- 5. COMMERCE / PAYMENTS ---
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY_HERE
STRIPE_PUBLISHABLE_KEY=YOUR_STRIPE_PUBLISHABLE_KEY_HERE
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET_HERE
GUMROAD_PRODUCT_URL=https://gumroad.com/l/your-product

# --- 6. MULTIMEDIA ---
ELEVENLABS_API_KEY=YOUR_ELEVENLABS_KEY_HERE
DEEPGRAM_API_KEY=YOUR_DEEPGRAM_KEY_HERE

# Sovereign Symphony (Multi-Voice Integration)
VOICE_KEY_OVERLORD=YOUR_OVERLORD_ELEVENLABS_KEY
VOICE_KEY_HUNTER=YOUR_HUNTER_ELEVENLABS_KEY
VOICE_KEY_HERALD=YOUR_HERALD_ELEVENLABS_KEY
VOICE_KEY_AUDITOR=YOUR_AUDITOR_ELEVENLABS_KEY
VOICE_KEY_SENTINEL=YOUR_SENTINEL_ELEVENLABS_KEY
VOICE_KEY_AUREUS=YOUR_AUREUS_ELEVENLABS_KEY
VOICE_KEY_KHAN=YOUR_KHAN_ELEVENLABS_KEY

# --- 7. DEPLOYMENT / DEVOPS ---
GITHUB_TOKEN=YOUR_GITHUB_PERSONAL_ACCESS_TOKEN_HERE
VERCEL_API_KEY=YOUR_VERCEL_KEY_HERE
HOSTINGER_API_KEY=YOUR_HOSTINGER_KEY_HERE
HOSTINGER_FTP_HOST=YOUR_HOST_IP_HERE
HOSTINGER_FTP_USER=YOUR_FTP_USER_HERE
HOSTINGER_FTP_PASSWORD=YOUR_FTP_PASSWORD_HERE
HOSTINGER_FTP_PORT=65002
HOSTINGER_FTP_PATH=/domains/your-domain.com/public_html/

# --- 8. SEARCH / INTELLIGENCE ---
BRAVE_API_KEY=YOUR_BRAVE_KEY_HERE
FIRECRAWL_API_KEY=YOUR_FIRECRAWL_KEY_HERE

# --- 9. SYSTEM SETTINGS ---
ENVIRONMENT=development
MOBILE_EXECUTION_DELAY=5000
PLATFORM=discord
MCP_ENABLED=false

# --- 10. FRONTEND (kings-swag-landing) ---
VITE_DOMAIN=http://localhost:3000
VITE_API_BASE=http://localhost:5050/api
VITE_REVENUE_POLL_MS=4000
VITE_LOGS_POLL_MS=2500
