# --- COMMUNICATIONS ---
# Discord Bot Token from Developer Portal
DISCORD_BOT_TOKEN=YOUR_DISCORD_BOT_TOKEN_HERE
# Specific Discord Channel ID for swarm logs
DISCORD_CHANNEL_ID=YOUR_CHANNEL_ID_HERE
# Optional: Webhook for high-fidelity alerts
DISCORD_WEBHOOK_URL=YOUR_WEBHOOK_URL_HERE

# --- INTELLIGENCE ---
# The primary brain (Ollama/Gemma for local, or GPT/Claude for cloud)
OLLAMA_MODEL=gemma31b
OPENROUTER_API_KEY=YOUR_OPENROUTER_KEY_HERE
ANTHROPIC_API_KEY=YOUR_CLAUDE_KEY_HERE
GOOGLE_API_KEY=YOUR_GCP_KEY_HERE

# --- MEMORY ---
# Tier 3 Cloud Persistence
DATABASE_URL=postgresql://user:pass@host:5052/postgres
# Tier 2 Semantic Persistence
PINECONE_API_KEY=YOUR_PINECONE_KEY_HERE
PINECONE_ENVIRONMENT=us-east-1

# --- COMMERCE & PAYMENTS ---
# Gumroad Product Link for B.L.A.S.T. Licenses
GUMROAD_PRODUCT_URL=https://gumroad.com/l/your-product
# MercadoPago Access Token for LATAM arbitrage
MERCADOPAGO_ACCESS_TOKEN=APP_USR-YOUR-TOKEN-HERE

# --- SYSTEM SETTINGS ---
# Delay between agent iterations (milliseconds)
MOBILE_EXECUTION_DELAY=5000
# Comm platform: "telegram", "discord", or "both"
PLATFORM=both
